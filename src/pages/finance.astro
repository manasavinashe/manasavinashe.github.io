---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { SITE } from "@/config";

const projects = await getCollection("projects", ({ data }) => data.category === "finance");

const sortedProjects = projects.sort(
  (a, b) =>
    Math.floor(new Date(b.data.pubDatetime).getTime() / 1000) -
    Math.floor(new Date(a.data.pubDatetime).getTime() / 1000)
);
---

<Layout title={`Finance Projects | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Finance" pageDesc="My projects in quantitative finance and algorithmic trading.">
    <ul>
      {sortedProjects.map(data => <ProjectCard {...data} />)}
    </ul>
  </Main>
  <Footer />
</Layout>
