---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ProjectCard from "@/components/ProjectCard.astro";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf()
);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Hello! नमस्ते! こんにちは! Guten Tag!
      </h1>
    </section>

    {
      projects.length > 0 && (
        <section id="projects" class="pt-12 pb-6 border-b border-border">
          <h2 class="text-2xl font-semibold tracking-wide">Projects</h2>
          <ul>
            {projects.map(data => (
              <ProjectCard variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", import.meta.env.BASE_URL);
    }
  });
</script>
